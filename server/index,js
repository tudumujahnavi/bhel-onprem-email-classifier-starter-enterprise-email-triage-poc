const express = require('express');
const app = express();
app.use(express.json());

// BHEL Rule-Based NLP Engine - 100% On-Premise, Zero External APIs
function classifyEmail(subject, body) {
  const text = (subject + " " + body).toLowerCase();
  if (text.includes('turbine') || text.includes('power') || text.includes('generation')) return 'Power';
  if (text.includes('invoice') || text.includes('payment') || text.includes('vendor')) return 'Finance';
  if (text.includes('safety') || text.includes('hr') || text.includes('leave')) return 'HR';
  if (text.includes('maintenance') || text.includes('breakdown')) return 'Maintenance';
  return 'General';
}

function getSentiment(text) {
  const t = text.toLowerCase();
  if (t.includes('urgent') || t.includes('asap') || t.includes('immediate')) return 'Urgent';
  if (t.includes('angry') || t.includes('complaint') || t.includes('unacceptable')) return 'Angry';
  if (t.includes('concerned') || t.includes('worried')) return 'Concerned';
  if (t.includes('thank') || t.includes('appreciate')) return 'Positive';
  return 'Neutral';
}

function getImportance(subject, body) {
  const text = (subject + " " + body).toLowerCase();
  if (text.includes('urgent') || text.includes('critical') || text.includes('breakdown')) return 'High';
  return 'Normal';
}

// API Routes for BHEL Dashboard
app.post('/api/classify', (req, res) => {
  const { subject, body } = req.body;
  res.json({
    department: classifyEmail(subject, body),
    sentiment: getSentiment(body),
    importance: getImportance(subject, body),
    replyTemplate: `Dear Sir/Madam, We have received your email regarding ${subject}. It has been forwarded to ${classifyEmail(subject, body)} department.`
  });
});

app.get('/api/stats', (req, res) => {
  res.json({ totalProcessed: 0, avgTime: '2s', offline: true });
});

app.listen(5000, () => {
  console.log('BHEL On-Prem Server running on port 5000');
  console.log('100% Offline. Zero external API calls. BHEL compliant.');
});
